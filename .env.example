# Copy this file to .env and fill in real values. .env is gitignored and
# will never be committed; this .example file is just the documented template.

# Seed default only: used the moment a chat self-registers with the bot
# (before it's run /setregion itself). Existing chats are unaffected --
# change a chat's region via the /setregion Telegram command instead.
REGION=

# Prices <= THRESHOLD are "ok", strictly above are "spike", below 0 is "negative".
# Seed default only: used the moment a chat self-registers with the bot
# (before it's run /setthreshold itself). Existing chats are unaffected --
# change a chat's threshold via the /setthreshold Telegram command instead.
THRESHOLD=30.0

TELEGRAM_BOT_TOKEN=
